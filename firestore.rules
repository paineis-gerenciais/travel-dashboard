rules_version = '2';
// Regras de segurança da Fase 2 (o item crítico).
// Modelo multi-viagem com compartilhamento por convite endereçado a e-mail.
//
// Princípios:
//  - Cada viagem tem uma lista `memberUids`. Só quem está nela lê/escreve.
//  - Conceder acesso = o CONVIDADO se auto-inclui (só ele conhece o próprio
//    uid), e só se existir um convite válido para o e-mail dele.
//  - Revogar acesso = o DONO remove da lista.
//  - Ninguém consulta a lista de e-mails de ninguém: cada um só lê os convites
//    destinados ao próprio e-mail (e o dono, os convites da própria viagem).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myEmail() { return request.auth.token.email; }
    function tripData(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId)).data;
    }
    function isMember(tripId) {
      return signedIn() && request.auth.uid in tripData(tripId).memberUids;
    }

    // Perfil do usuário — cada um só o seu (usado para exibir nomes; privado).
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Viagens
    match /trips/{tripId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;

      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      allow update: if signedIn() && (
        // A) membro editando conteúdo, sem mexer na lista de membros nem no dono
        ( request.auth.uid in resource.data.memberUids
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.memberUids == resource.data.memberUids )
        ||
        // B) dono gerenciando a lista de membros (revogar acesso)
        ( resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId )
        ||
        // C) convidado se auto-incluindo — adiciona SÓ a si mesmo, e só se houver
        //    um convite válido para o e-mail dele naquela viagem
        ( !(request.auth.uid in resource.data.memberUids)
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.memberUids.removeAll(resource.data.memberUids) == [request.auth.uid]
          && resource.data.memberUids.removeAll(request.resource.data.memberUids).size() == 0
          && request.resource.data.ownerId == resource.data.ownerId
          && exists(/databases/$(database)/documents/convites/$(tripId + '_' + myEmail())) )
      );

      // Versões — herdam o acesso da viagem
      match /versions/{versionId} {
        allow read, write: if isMember(tripId);
      }

      // Presença — membros leem; cada um escreve só o próprio doc
      match /presence/{uid} {
        allow read: if isMember(tripId);
        allow write: if signedIn() && request.auth.uid == uid && isMember(tripId);
      }

      // Info de exibição de membros (nome/e-mail/papel)
      match /members/{uid} {
        allow read: if isMember(tripId);
        allow write: if signedIn() && request.auth.uid == uid && isMember(tripId);
        allow delete: if signedIn() && tripData(tripId).ownerId == request.auth.uid;
      }
    }

    // Convites
    match /convites/{conviteId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      // convidado lê os seus; dono lê os da própria viagem
      allow read: if signedIn() && (
        resource.data.emailConvidado == myEmail()
        || resource.data.ownerUid == request.auth.uid
      );
      // convidado aceita/recusa o seu; dono cancela o que criou
      allow update, delete: if signedIn() && (
        resource.data.emailConvidado == myEmail()
        || resource.data.ownerUid == request.auth.uid
      );
    }

    // Tudo o mais é negado.
    match /{document=**} { allow read, write: if false; }
  }
}
