# Configuração do Firebase (Console do Firebase > Configurações do projeto > Seus apps > Web).
# Copie este arquivo para ".env" e preencha. Estas chaves NÃO são secretas
# (são identificadores públicos do projeto); a segurança vem das regras do
# Firestore (firestore.rules), não do sigilo destas variáveis.
VITE_FIREBASE_API_KEY=sua-api-key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
